<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/pink</item>
        <item name="colorPrimaryDark">@color/pink_dark</item>
        <item name="colorAccent">@color/purple</item>
        <item name="android:windowBackground">@drawable/gradient_background</item>
        <item name="android:statusBarColor">@color/pink_dark</item>
        <item name="android:navigationBarColor">@color/pink_light</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/pink_dark</item>
    </style>

    <!-- Dialog Theme -->
    <style name="DialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorPrimary">@color/pink</item>
        <item name="colorAccent">@color/pink_dark</item>
        <item name="android:windowBackground">@drawable/dialog_background</item>
    </style>

    <!-- Pink Dialog Theme -->
    <style name="PinkDialogTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>

    <!-- Text Input Layout Styles -->
    <style name="OutlinedBoxStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/pink</item>
        <item name="hintTextColor">@color/pink_dark</item>
        <item name="android:textColorHint">@color/pink_light</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Button Styles -->
    <style name="PinkButton">
        <item name="android:background">@drawable/button_pink_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Text Styles -->
    <style name="TitleText">
        <item name="android:textColor">@color/pink_dark</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SubtitleText">
        <item name="android:textColor">@color/pink</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BodyText">
        <item name="android:textColor">@color/dark_gray</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="CaptionText">
        <item name="android:textColor">@color/medium_gray</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Edit Text Style -->
    <style name="PinkEditText">
        <item name="android:background">@drawable/edittext_pink_border</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/dark_gray</item>
        <item name="android:textColorHint">@color/medium_gray</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Card View Style -->
    <style name="PinkCardView">
        <item name="cardCornerRadius">15dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>
</resources>