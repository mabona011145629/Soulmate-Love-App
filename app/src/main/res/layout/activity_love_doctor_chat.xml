<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Floating Hearts Background -->
    <ImageView
        android:id="@+id/heartImage1"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/heart_pink"
        android:alpha="0.3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginTop="60dp" />

    <ImageView
        android:id="@+id/heartImage2"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/heart_red"
        android:alpha="0.25"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="100dp" />

    <ImageView
        android:id="@+id/heartImage3"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@drawable/heart_purple"
        android:alpha="0.2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/messagesRecyclerView"
        android:layout_marginStart="50dp"
        android:layout_marginBottom="20dp" />

    <!-- Top Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/pink_dark" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                app:layout_constraintStart_toEndOf="@+id/backButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/invitePartnerIcon">

                <TextView
                    android:id="@+id/doctorNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Love Doctor"
                    android:textColor="@color/pink_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/onlineStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💕 Therapy Session"
                    android:textColor="@color/green"
                    android:textSize="11sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/invitePartnerIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_add_user"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/pink_dark" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/messageInputContainer" />

    <!-- Voice Recording Panel -->
    <LinearLayout
        android:id="@+id/voiceRecordingPanel"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/white"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/cancelVoiceBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_close"
            android:padding="12dp"
            android:tint="@color/red" />

        <TextView
            android:id="@+id/voiceRecordingTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/red"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="20dp" />

        <ImageView
            android:id="@+id/sendVoiceBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_send"
            android:padding="12dp"
            android:tint="@color/pink" />

    </LinearLayout>

    <!-- Message Input Container -->
    <LinearLayout
        android:id="@+id/messageInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Attachment Panel -->
        <LinearLayout
            android:id="@+id/attachmentPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:id="@+id/attachImageBtn"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="25dp"
                app:cardBackgroundColor="@color/pink_light"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_image"
                    android:tint="@color/pink_dark" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/attachVideoBtn"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="25dp"
                app:cardBackgroundColor="@color/pink_light"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_video"
                    android:tint="@color/pink_dark" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView                android:id="@+id/attachMusicBtn"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="25dp"
                app:cardBackgroundColor="@color/pink_light"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_music"
                    android:tint="@color/pink_dark" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Input Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/attachButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_attach"
                android:padding="8dp"
                android:tint="@color/pink_dark"
                android:clickable="true"
                android:focusable="true" />

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Type your message..."
                android:background="@drawable/edittext_pink_border"
                android:padding="12dp"
                android:textColor="@color/dark_gray"
                android:textSize="14sp"
                android:maxLines="5"
                android:inputType="textMultiLine" />

            <ImageView
                android:id="@+id/voiceButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_mic"
                android:padding="8dp"
                android:tint="@color/pink_dark"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/sendButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_send"
                android:padding="8dp"
                android:tint="@color/pink"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>