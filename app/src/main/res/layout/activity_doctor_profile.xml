<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Floating Hearts -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false">

        <ImageView
            android:id="@+id/heartImage1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/heart_pink"
            android:alpha="0.3"
            android:layout_gravity="start|top"
            android:layout_marginStart="20dp"
            android:layout_marginTop="60dp" />

        <ImageView
            android:id="@+id/heartImage2"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/heart_red"
            android:alpha="0.25"
            android:layout_gravity="end|top"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="100dp" />

        <ImageView
            android:id="@+id/heartImage3"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/heart_purple"
            android:alpha="0.2"
            android:layout_gravity="center|top"
            android:layout_marginTop="130dp" />

    </FrameLayout>

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@color/white">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/pink_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doctor Profile"
                android:textColor="@color/pink_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@+id/backButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="16dp"
        android:paddingTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Profile Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <!-- Profile Image -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/profileImageCard"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="4dp">

                        <ImageView
                            android:id="@+id/profileImageView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/default_profile"
                            android:scaleType="centerCrop" />

                    </androidx.cardview.widget.CardView>

                    <!-- Online Indicator -->
                    <ImageView
                        android:id="@+id/onlineIndicator"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/circle_green"
                        android:layout_marginTop="-16dp"
                        android:layout_marginEnd="-16dp"
                        android:layout_gravity="end"
                        android:visibility="gone" />

                    <!-- Name -->
                    <TextView
                        android:id="@+id/nameTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Doctor Name"
                        android:textColor="@color/pink_dark"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- Qualification Badge -->
                    <TextView
                        android:id="@+id/qualificationBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Psychologist"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/badge_pink"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="8dp" />

                    <!-- Rating Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/ratingText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 4.8"
                            android:textColor="@color/green"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/reviewCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(124 reviews)"
                            android:textColor="@color/medium_gray"
                            android:textSize="12sp"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                    <!-- Session Count -->
                    <TextView
                        android:id="@+id/sessionsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500+ successful sessions"
                        android:textColor="@color/pink"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                    <!-- Bio -->
                    <TextView
                        android:id="@+id/bioTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bio goes here..."
                        android:textColor="@color/dark_gray"
                        android:textSize="14sp"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginVertical="16dp" />

                    <!-- Qualifications Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📜 Qualifications and Experience"
                        android:textColor="@color/pink_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/qualificationsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Qualification details here..."
                        android:textColor="@color/dark_gray"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginVertical="16dp" />

                    <!-- Pricing Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰 Pricing"
                        android:textColor="@color/pink_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/sessionPriceText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="E150 per session"
                            android:textColor="@color/pink"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/hourlyRateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="or E80/hour"
                        android:textColor="@color/medium_gray"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Rating Section -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_gray"
                        android:layout_marginVertical="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ Rate this Doctor"
                        android:textColor="@color/pink_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <RatingBar
                        android:id="@+id/doctorRatingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="1"
                        android:theme="@style/Widget.AppCompat.RatingBar"
                        android:progressTint="@color/pink"
                        android:layout_gravity="center" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/submitRatingButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/pink_dark"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:paddingHorizontal="24dp"
                            android:gravity="center"
                            android:text="Submit Rating"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </androidx.cardview.widget.CardView>

                    <!-- Chat Button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/chatButton"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="27dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="@color/pink"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="💬 Start Therapy Session"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>