<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Profile Image -->
        <androidx.cardview.widget.CardView
            android:id="@+id/profileImageCard"
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/profileImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/default_profile"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true" />

        </androidx.cardview.widget.CardView>

        <!-- Online Indicator -->
        <ImageView
            android:id="@+id/onlineIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/circle_green"
            android:layout_marginTop="-16dp"
            android:layout_marginEnd="-16dp"
            android:layout_gravity="end"
            android:visibility="gone" />

        <!-- Name -->
        <TextView
            android:id="@+id/nameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textColor="@color/pink_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <!-- Gender -->
        <TextView
            android:id="@+id/genderTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textColor="@color/medium_gray"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- Love Doctor Badge -->
        <TextView
            android:id="@+id/loveDoctorBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👨‍⚕️ Love Doctor"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/badge_pink"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Rating (for love doctors) -->
        <LinearLayout
            android:id="@+id/ratingLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/ratingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 4.8"
                android:textColor="@color/green"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sessionsCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" (124 sessions)"
                android:textColor="@color/medium_gray"
                android:textSize="12sp"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Bio -->
        <TextView
            android:id="@+id/bioTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bio goes here..."
            android:textColor="@color/dark_gray"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp" />

        <!-- Phone (only visible to owner) -->
        <TextView
            android:id="@+id/phoneTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 +27 XX XXX XXXX"
            android:textColor="@color/medium_gray"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:drawableStart="@drawable/ic_phone"
            android:drawablePadding="6dp"
            android:visibility="gone" />

        <!-- Location -->
        <TextView
            android:id="@+id/locationTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Location"
            android:textColor="@color/medium_gray"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:drawableStart="@drawable/ic_location"
            android:drawablePadding="6dp"
            android:visibility="gone" />

        <!-- Action Buttons (Chat & Send Love) -->
        <LinearLayout
            android:id="@+id/actionButtonsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:id="@+id/chatButton"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="@color/pink"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="💬 Chat"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/requestLoveButton"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="@color/purple"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="❤️ Send Love"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_gray"
            android:layout_marginTop="16dp" />

        <!-- Posts Section Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📝 Posts"
                android:textColor="@color/pink_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/noPostsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No posts yet"
                android:textColor="@color/medium_gray"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>