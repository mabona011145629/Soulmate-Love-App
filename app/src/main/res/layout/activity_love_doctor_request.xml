<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@color/white">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/pink_dark" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍⚕️ Become a Love Doctor"
                android:textColor="@color/pink_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@+id/backButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Floating Hearts Background -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ImageView
            android:id="@+id/heartImage1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/heart_pink"
            android:alpha="0.3"
            android:layout_gravity="start|top"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp" />

        <ImageView
            android:id="@+id/heartImage2"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/heart_red"
            android:alpha="0.25"
            android:layout_gravity="end|top"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="50dp" />

        <ImageView
            android:id="@+id/heartImage3"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/heart_purple"
            android:alpha="0.2"
            android:layout_gravity="center|top"
            android:layout_marginTop="80dp" />

    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="16dp"
        android:paddingTop="120dp">

        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💗 Help Others Find Love"
                        android:textColor="@color/pink_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="By becoming a Love Doctor, you'll help people navigate relationships, heal from heartbreak, and build healthy connections. Your expertise can save relationships and even lives."
                        android:textColor="@color/dark_gray"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Summary Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/summaryLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="📝 Why do you want to be a Love Doctor? *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/summaryInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="4"
                    android:maxLines="8"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Qualifications Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/qualificationsLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="🎓 List your qualifications/experience *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/qualificationsInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:maxLines="6"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Qualification Type Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/qualificationTypeLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="👔 Qualification Type *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/qualificationTypeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_dropdown"
                    android:inputType="none" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Social Media Links Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐 Social Media Profiles (Optional)"
                android:textColor="@color/pink_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <!-- Facebook URL -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/facebookLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="📘 Facebook Profile URL">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/facebookInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- YouTube URL -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/youtubeLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="📺 YouTube Channel URL">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/youtubeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Instagram URL -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/instagramLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="📸 Instagram Profile URL">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/instagramInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Pricing Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 Pricing Information"
                android:textColor="@color/pink_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <!-- Hourly Rate -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/hourlyRateLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="💰 Hourly Rate (E) *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/hourlyRateInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Session Price -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/sessionPriceLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxStrokeColor="@color/pink"
                app:hintTextColor="@color/pink_dark"
                android:hint="💕 Per Session Price (E) *">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/sessionPriceInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/dark_gray"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/submitButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="27dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/pink"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/submitButtonText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="💕 Submit Application"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

            <!-- Terms Text -->
            <TextView
                android:id="@+id/termsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="By submitting, you agree to our Love Doctor Guidelines"
                android:textColor="@color/medium_gray"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Note about documents -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/background_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📧 Important Note"
                        android:textColor="@color/pink_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="After submitting, please email your supporting documents (certificates, credentials, ID) to support@soulmate.com with subject: 'Love Doctor Docs - [Your Name]'"
                        android:textColor="@color/dark_gray"
                        android:textSize="11sp"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>